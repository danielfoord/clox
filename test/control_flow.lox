fun assert(condition, message) {
  if (condition) {
    print "PASS: " + message;
  } else {
    print "FAIL: " + message;
  }
}

var x = 0;
if (true) x = 1; else x = 2;
assert(x == 1, "If true");

if (false) x = 1; else x = 2;
assert(x == 2, "Else branch");

var count = 0;
while (count < 3) count = count + 1;
assert(count == 3, "While loop");

var sum = 0;
for (var i = 0; i < 5; i = i + 1) sum = sum + i;
assert(sum == 10, "For loop");
